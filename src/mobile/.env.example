# Mobile (Expo) — copie para .env (ignorado pelo git).
# Variáveis EXPO_PUBLIC_* são embutidas no bundle em tempo de build.

# Raiz da API (sem /api no final). Em dev local aponta para a API .NET.
# A produção deve definir isto no eas.json (build profiles).
EXPO_PUBLIC_API_URL=http://localhost:5089
