{
  "expo": {
    "name": "Agendify",
    "slug": "agendify",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "agendify",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#5E35B1"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.agendify.app",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Precisamos de permissão para selecionar fotos da galeria",
        "NSCameraUsageDescription": "Precisamos de permissão para tirar fotos"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#5E35B1"
      },
      "package": "com.agendify.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#5E35B1",
          "imageWidth": 200
        }
      ],
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      "expo-font",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      }
    }
  }
}
