@page
@model web.Pages.Bookings.CreateModel
@{
    ViewData["Title"] = "Nova Reserva";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <h1>Nova Reserva</h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-page="/Dashboard">Dashboard</a></li>
                    <li class="breadcrumb-item"><a asp-page="/Bookings/My">Minhas Reservas</a></li>
                    <li class="breadcrumb-item active">Nova</li>
                </ol>
            </nav>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-body">
                    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                    {
                        <div class="alert alert-danger" role="alert">
                            @Model.ErrorMessage
                        </div>
                    }

                    <form method="post">
                        <div id="spacePreview" class="mb-4" style="display: none;">
                            <div class="card border-warning">
                                <div class="row g-0">
                                    <div class="col-md-4">
                                        <img id="spaceImage" src="" alt="Space image" class="img-fluid rounded-start" style="width: 100%; height: 200px; object-fit: cover;" />
                                    </div>
                                    <div class="col-md-8">
                                        <div class="card-body">
                                            <h5 class="card-title" id="spaceName"></h5>
                                            <p class="card-text" id="spaceDescription"></p>
                                            <p class="card-text">
                                                <small class="text-muted">
                                                    <strong>Capacidade:</strong> <span id="spaceCapacity"></span> pessoas
                                                </small>
                                            </p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="SpaceId" class="form-label">Espaço</label>
                            <select asp-for="SpaceId" class="form-select" id="spaceSelect">
                                <option value="">Selecione um espaço</option>
                                @foreach (var space in Model.Spaces)
                                {
                                    <option value="@space.Id">@space.Name (@space.Capacity pessoas)</option>
                                }
                            </select>
                            <span asp-validation-for="SpaceId" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="BookingDate" class="form-label">Data da Reserva</label>
                            <input asp-for="BookingDate" type="date" class="form-control" id="bookingDate" min="@DateTime.Now.ToString("yyyy-MM-dd")" />
                            <small class="form-text text-muted">Não é possível fazer reservas em datas passadas</small>
                            <span asp-validation-for="BookingDate" class="text-danger"></span>
                        </div>

                        <div id="timeSlotsSection" style="display: none;">
                            <div class="mb-3">
                                <label class="form-label">Horários Disponíveis</label>
                                <small class="form-text text-muted d-block mb-2">Selecione os horários desejados (você pode selecionar múltiplos horários consecutivos)</small>
                                <div id="timeSlotsContainer" class="border rounded p-3 bg-light">
                                    <div class="text-center text-muted">
                                        <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                        Carregando horários disponíveis...
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div id="noSpaceSelectedMessage" class="alert alert-info">
                            <i class="bi bi-info-circle"></i> Selecione um espaço e uma data para ver os horários disponíveis.
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">Criar Reserva</button>
                            <a asp-page="/Bookings/My" class="btn btn-outline-secondary">Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm bg-light">
                <div class="card-body">
                    <h5 class="card-title">Dicas</h5>
                    <ul class="small">
                        <li>Selecione um espaço e data para ver os horários disponíveis</li>
                        <li>Horários com <span class="badge bg-success">Disponível</span> podem ser reservados</li>
                        <li>Horários com <span class="badge bg-danger">Reservado</span> já estão ocupados</li>
                        <li>Horários com <span class="badge bg-secondary">Indisponível</span> não podem ser reservados</li>
                        <li><strong>Espaços de dia inteiro:</strong> Podem ser reservados mesmo se o horário de início já passou, desde que o horário de término ainda não tenha chegado</li>
                        <li><strong>Espaços por hora:</strong> Horários que já passaram não podem ser reservados</li>
                        <li>Você pode selecionar múltiplos horários consecutivos</li>
                        <li>Verifique a capacidade do espaço antes de reservar</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const spacesData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Spaces));
        let currentAvailability = null;
        
        function updateSpacePreview(selectedSpaceId) {
            const previewDiv = document.getElementById('spacePreview');
            
            if (!selectedSpaceId) {
                previewDiv.style.display = 'none';
                return;
            }
            
            const selectedSpace = spacesData.find(space => space.Id === selectedSpaceId);
            
            if (selectedSpace) {
                document.getElementById('spaceName').textContent = selectedSpace.Name;
                document.getElementById('spaceDescription').textContent = selectedSpace.Description || 'Sem descrição disponível';
                document.getElementById('spaceCapacity').textContent = selectedSpace.Capacity;
                
                const imageUrl = selectedSpace.ImageUrl 
                    ? `@Model.ApiBaseUrl${selectedSpace.ImageUrl}`
                    : '/images/placeholder.jpg';
                document.getElementById('spaceImage').src = imageUrl;
                
                previewDiv.style.display = 'block';
                previewDiv.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            }
        }
        
        async function loadTimeSlots() {
            const spaceId = document.getElementById('spaceSelect').value;
            const date = document.getElementById('bookingDate').value;
            const timeSlotsSection = document.getElementById('timeSlotsSection');
            const noSpaceMessage = document.getElementById('noSpaceSelectedMessage');
            const container = document.getElementById('timeSlotsContainer');
            
            if (!spaceId || !date) {
                timeSlotsSection.style.display = 'none';
                noSpaceMessage.style.display = 'block';
                return;
            }
            
            noSpaceMessage.style.display = 'none';
            timeSlotsSection.style.display = 'block';
            container.innerHTML = '<div class="text-center text-muted"><span class="spinner-border spinner-border-sm me-2" role="status"></span>Carregando horários disponíveis...</div>';
            
            try {
                const userTimezone = Intl.DateTimeFormat().resolvedOptions().timeZone;
                
                const response = await fetch(`@Model.ApiBaseUrl/api/spaces/${spaceId}/availability?date=${date}&timezone=${encodeURIComponent(userTimezone)}`, {
                    headers: {
                        'Authorization': 'Bearer ' + '@HttpContext.Session.GetString("AuthToken")'
                    }
                });
                
                if (!response.ok) {
                    throw new Error('Erro ao carregar disponibilidade');
                }
                
                currentAvailability = await response.json();
                displayTimeSlots(currentAvailability);
            } catch (error) {
                console.error('Error loading time slots:', error);
                container.innerHTML = '<div class="alert alert-danger">Erro ao carregar horários disponíveis. Tente novamente.</div>';
            }
        }
        
        function displayTimeSlots(availability) {
            const container = document.getElementById('timeSlotsContainer');
            
            if (!availability.timeSlots || availability.timeSlots.length === 0) {
                if (availability.isAllDayBooking) {
                    container.innerHTML = '<div class="alert alert-info"><i class="bi bi-info-circle"></i> Este espaço é de reserva de dia inteiro, mas não possui horários configurados. Entre em contato com a administração.</div>';
                } else {
                    container.innerHTML = '<div class="alert alert-warning">Este espaço não possui horários configurados.</div>';
                }
                return;
            }
            
            let html;
            
            if (availability.isAllDayBooking) {
                const slot = availability.timeSlots[0];
                html = `<div class="alert alert-info mb-3"><i class="bi bi-info-circle"></i> Este espaço é reservado por dia inteiro das <strong>${slot.startTime}</strong> até <strong>${slot.endTime}</strong></div>`;
                html += '<div class="row g-2">';
                
                const isDisabled = !slot.isAvailable;
                const statusClass = isDisabled ? 'text-muted' : '';
                
                let statusBadge;
                if (slot.isPast) {
                    statusBadge = '<span class="badge bg-secondary ms-2">Indisponível</span>';
                } else if (slot.isBooked) {
                    statusBadge = '<span class="badge bg-danger ms-2">Já reservado</span>';
                } else {
                    statusBadge = '<span class="badge bg-success ms-2">Disponível</span>';
                }
                
                html += `
                    <div class="col-12">
                        <div class="form-check p-4 border rounded ${isDisabled ? 'bg-light' : 'bg-white border-primary'}" style="cursor: ${isDisabled ? 'not-allowed' : 'pointer'}">
                            <input class="form-check-input time-slot-checkbox" 
                                   type="checkbox" 
                                   name="SelectedTimeSlots" 
                                   value="${slot.startTime}" 
                                   id="slot_allday"
                                   ${isDisabled ? 'disabled' : ''}
                                   data-start="${slot.startTime}"
                                   data-end="${slot.endTime}">
                            <label class="form-check-label ${statusClass}" for="slot_allday" style="font-size: 1.1rem;">
                                <i class="bi bi-calendar-event"></i> 
                                <strong>Reserva de Dia Inteiro</strong><br>
                                <span class="ms-4">Das <strong>${slot.startTime}</strong> até <strong>${slot.endTime}</strong></span>
                                ${statusBadge}
                            </label>
                        </div>
                    </div>
                `;
                html += '</div>';
            } else {
                html = '<div class="row g-2">';
                
                availability.timeSlots.forEach(slot => {
                    const isDisabled = !slot.isAvailable;
                    const statusClass = isDisabled ? 'text-muted' : '';
                    
                    let statusBadge;
                    if (slot.isPast) {
                        statusBadge = '<span class="badge bg-secondary ms-2">Indisponível</span>';
                    } else if (slot.isBooked) {
                        statusBadge = '<span class="badge bg-danger ms-2">Reservado</span>';
                    } else {
                        statusBadge = '<span class="badge bg-success ms-2">Disponível</span>';
                    }
                    
                    html += `
                        <div class="col-md-6 col-lg-4">
                            <div class="form-check p-3 border rounded ${isDisabled ? 'bg-light' : 'bg-white'}">
                                <input class="form-check-input time-slot-checkbox" 
                                       type="checkbox" 
                                       name="SelectedTimeSlots" 
                                       value="${slot.startTime}" 
                                       id="slot_${slot.startTime.replace(':', '')}"
                                       ${isDisabled ? 'disabled' : ''}
                                       data-start="${slot.startTime}"
                                       data-end="${slot.endTime}">
                                <label class="form-check-label ${statusClass}" for="slot_${slot.startTime.replace(':', '')}">
                                    <strong>${slot.startTime}</strong> até <strong>${slot.endTime}</strong>
                                    ${statusBadge}
                                </label>
                            </div>
                        </div>
                    `;
                });
                
                html += '</div>';
            }
            
            container.innerHTML = html;
            
            document.querySelectorAll('.time-slot-checkbox').forEach(checkbox => {
                checkbox.addEventListener('change', updateSelectedSummary);
            });
        }
        
        function updateSelectedSummary() {
            const checkboxes = Array.from(document.querySelectorAll('.time-slot-checkbox:checked'));
            
            if (checkboxes.length === 0) {
                return;
            }
            
            const times = checkboxes.map(cb => cb.dataset.start).sort();
            const firstTime = times[0];
            const lastCheckbox = checkboxes.find(cb => cb.dataset.start === times[times.length - 1]);
            const lastTime = lastCheckbox.dataset.end;
            
            console.log(`Selected: ${firstTime} to ${lastTime} (${checkboxes.length} slot(s))`);
        }
        
        document.getElementById('spaceSelect').addEventListener('change', function(e) {
            updateSpacePreview(e.target.value);
            loadTimeSlots();
        });
        
        document.getElementById('bookingDate').addEventListener('change', loadTimeSlots);
        
        window.addEventListener('DOMContentLoaded', function() {
            const spaceSelect = document.getElementById('spaceSelect');
            if (spaceSelect.value) {
                updateSpacePreview(spaceSelect.value);
                loadTimeSlots();
            }
        });
    </script>
}

