@page
@model web.Pages.Bookings.MyModel
@{
    ViewData["Title"] = "Minhas Reservas";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <h1>Minhas Reservas</h1>
                <a asp-page="/Bookings/Create" class="btn btn-primary">
                    <i class="bi bi-plus-circle"></i> Nova Reserva
                </a>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.Message))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @Model.Message
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @Model.ErrorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-4">
        @foreach (var booking in Model.Bookings.OrderByDescending(b => b.StartDateTime))
        {
            var localStartTime = booking.StartDateTime.Kind == DateTimeKind.Utc 
                ? booking.StartDateTime.ToLocalTime() 
                : booking.StartDateTime;
            var localEndTime = booking.EndDateTime.Kind == DateTimeKind.Utc 
                ? booking.EndDateTime.ToLocalTime() 
                : booking.EndDateTime;
            var now = DateTime.Now;
            
            var isPast = localEndTime < now;
            var isFuture = localStartTime > now;
            
            <div class="col-md-6 col-lg-4">
                <div class="card shadow-sm h-100 @(isPast ? "border-secondary" : "")">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <h5 class="card-title">@(booking.Space?.Name ?? "Espaço não encontrado")</h5>
                            @if (isPast)
                            {
                                <span class="badge bg-secondary">Concluído</span>
                            }
                            else if (isFuture)
                            {
                                <span class="badge bg-primary">Agendado</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Em andamento</span>
                            }
                        </div>
                        
                        <div class="mb-2">
                            <small class="text-muted">
                                <i class="bi bi-calendar"></i> Início: @localStartTime.ToString("dd/MM/yyyy HH:mm")
                            </small>
                        </div>
                        <div class="mb-3">
                            <small class="text-muted">
                                <i class="bi bi-calendar-check"></i> Fim: @localEndTime.ToString("dd/MM/yyyy HH:mm")
                            </small>
                        </div>

                        @if (!isPast)
                        {
                            <form method="post" asp-page-handler="Cancel" asp-route-id="@booking.Id" class="mt-3">
                                <button type="submit" class="btn btn-sm btn-outline-danger w-100" 
                                        onclick="return confirm('Tem certeza que deseja cancelar esta reserva?')">
                                    <i class="bi bi-x-circle"></i> Cancelar Reserva
                                </button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        }
    </div>

    @if (!Model.Bookings.Any())
    {
        <div class="text-center py-5">
            <p class="text-muted">Você ainda não tem reservas.</p>
            <a asp-page="/Bookings/Create" class="btn btn-primary">Criar Primeira Reserva</a>
        </div>
    }
</div>

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
}

