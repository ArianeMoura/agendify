@using web.Services
@inject AuthService AuthService

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Agendify</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    @if (AuthService.IsAuthenticated())
    {
        <!-- Sidebar -->
        <div class="sidebar" id="sidebar">
            <div class="sidebar-header">
                <a href="/Dashboard" class="sidebar-brand">
                    <i class="bi bi-calendar-check"></i>
                    <span class="brand-text">Agendify</span>
                </a>
                <button class="sidebar-collapse-btn" id="sidebarCollapseBtn" title="Expandir/Recolher">
                    <i class="bi bi-chevron-left"></i>
                </button>
            </div>

            <div class="sidebar-menu">
                <a asp-page="/Dashboard" class="sidebar-item" title="Dashboard">
                    <i class="bi bi-house-door"></i>
                    <span>Dashboard</span>
                </a>

                @if (AuthService.IsAdmin())
                {
                    <div class="sidebar-divider">Administração</div>

                    <a asp-page="/Admin/Users/Index" class="sidebar-item" title="Usuários">
                        <i class="bi bi-people"></i>
                        <span>Usuários</span>
                    </a>

                    <a asp-page="/Admin/Spaces/Index" class="sidebar-item" title="Espaços">
                        <i class="bi bi-building"></i>
                        <span>Espaços</span>
                    </a>

                    <a asp-page="/Admin/Bookings/Index" class="sidebar-item" title="Reservas">
                        <i class="bi bi-calendar-check"></i>
                        <span>Reservas</span>
                    </a>

                    <!-- NOVO ITEM: Analytics -->
                    <a asp-page="/Analytics" class="sidebar-item" title="Analytics">
                        <i class="bi bi-bar-chart-line"></i>
                        <span>Analytics</span>
                    </a>
                }
                else
                {
                    <div class="sidebar-divider">Minhas Reservas</div>

                    <a asp-page="/Bookings/Create" class="sidebar-item" title="Nova Reserva">
                        <i class="bi bi-plus-circle"></i>
                        <span>Nova Reserva</span>
                    </a>

                    <a asp-page="/Bookings/My" class="sidebar-item" title="Minhas Reservas">
                        <i class="bi bi-calendar-event"></i>
                        <span>Minhas Reservas</span>
                    </a>
                }
            </div>

            <div class="sidebar-footer">
                <small class="sidebar-footer-text">© @DateTime.Now.Year Agendify</small>
            </div>
        </div>

        <!-- Mobile Toggle Button -->
        <button class="sidebar-toggle d-lg-none" id="sidebarToggle">
            <i class="bi bi-list"></i>
        </button>

        <!-- Main Content Wrapper -->
        <div class="main-wrapper">
            <!-- Top Bar -->
            <div class="topbar">
                <div class="topbar-left">
                    <h5 class="mb-0">@ViewData["Title"]</h5>
                </div>
                <div class="topbar-right">
                    <div class="dropdown">
                        <button class="btn btn-user dropdown-toggle" type="button" data-bs-toggle="dropdown">
                            <i class="bi bi-person-circle me-2"></i>
                            <span class="user-name">@AuthService.GetUserName()</span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li>
                                <a class="dropdown-item" asp-page="/Profile/Edit">
                                    <i class="bi bi-person-gear me-2"></i> Editar Perfil
                                </a>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <a class="dropdown-item text-danger" asp-page="/Logout">
                                    <i class="bi bi-box-arrow-right me-2"></i> Sair
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>

            <!-- Main Content -->
            <main class="main-content">
                @RenderBody()
            </main>

            <!-- Footer -->
            <footer class="main-footer">
                <div class="container-fluid">
                    <span class="text-muted">@DateTime.Now.Year - Agendify</span>
                </div>
            </footer>
        </div>
    }
    else
    {
        <!-- Login/Register pages without sidebar -->
        @RenderBody()
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

    @if (AuthService.IsAuthenticated())
    {
        <script>
            // Sidebar collapse/expand toggle
            const sidebar = document.getElementById('sidebar');
            const mainWrapper = document.querySelector('.main-wrapper');
            const collapseBtn = document.getElementById('sidebarCollapseBtn');
            const collapseBtnIcon = collapseBtn?.querySelector('i');

            // Load saved state from localStorage
            const savedState = localStorage.getItem('sidebarCollapsed');
            if (savedState === 'true') {
                sidebar.classList.add('collapsed');
                mainWrapper.classList.add('sidebar-collapsed');
            }

            // Collapse/Expand button click
            collapseBtn?.addEventListener('click', function(e) {
                e.stopPropagation();
                sidebar.classList.toggle('collapsed');
                mainWrapper.classList.toggle('sidebar-collapsed');

                // Update icon
                if (sidebar.classList.contains('collapsed')) {
                    collapseBtnIcon.classList.remove('bi-chevron-left');
                    collapseBtnIcon.classList.add('bi-chevron-right');
                    localStorage.setItem('sidebarCollapsed', 'true');
                } else {
                    collapseBtnIcon.classList.remove('bi-chevron-right');
                    collapseBtnIcon.classList.add('bi-chevron-left');
                    localStorage.setItem('sidebarCollapsed', 'false');
                }
            });

            // Update icon on page load
            if (sidebar.classList.contains('collapsed') && collapseBtnIcon) {
                collapseBtnIcon.classList.remove('bi-chevron-left');
                collapseBtnIcon.classList.add('bi-chevron-right');
            }

            // Sidebar toggle for mobile
            document.getElementById('sidebarToggle')?.addEventListener('click', function() {
                sidebar.classList.toggle('active');
            });

            // Close sidebar when clicking outside on mobile
            document.addEventListener('click', function(event) {
                const toggle = document.getElementById('sidebarToggle');

                if (window.innerWidth < 992) {
                    if (!sidebar.contains(event.target) && !toggle.contains(event.target)) {
                        sidebar.classList.remove('active');
                    }
                }
            });

            // Active menu item highlight
            const currentPath = window.location.pathname;
            document.querySelectorAll('.sidebar-item').forEach(item => {
                const href = item.getAttribute('href');
                if (href && currentPath.includes(href)) {
                    item.classList.add('active');
                }
            });
        </script>
    }
</body>
</html>