@page
@model web.Pages.DashboardModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <h1 class="mb-4">Bem-vindo, @Model.UserName!</h1>
        </div>
    </div>

    @if (Model.IsAdmin)
    {
        <div class="row g-4 mb-4">
            <div class="col-md-4">
                <div class="card shadow-sm h-100">
                    <div class="card-body text-center">
                        <div class="display-4 text-primary mb-3">
                            <i class="bi bi-people-fill"></i>
                        </div>
                        <h5 class="card-title">Gerenciar Usuários</h5>
                        <p class="card-text text-muted">Visualize, crie e gerencie usuários do sistema</p>
                        <a asp-page="/Admin/Users/Index" class="btn btn-primary">Acessar</a>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card shadow-sm h-100">
                    <div class="card-body text-center">
                        <div class="display-4 text-warning mb-3">
                            <i class="bi bi-building"></i>
                        </div>
                        <h5 class="card-title">Gerenciar Espaços</h5>
                        <p class="card-text text-muted">Adicione, edite e remova espaços disponíveis</p>
                        <a asp-page="/Admin/Spaces/Index" class="btn btn-warning">Acessar</a>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card shadow-sm h-100">
                    <div class="card-body text-center">
                        <div class="display-4 text-success mb-3">
                            <i class="bi bi-calendar-check"></i>
                        </div>
                        <h5 class="card-title">Gerenciar Reservas</h5>
                        <p class="card-text text-muted">Visualize e gerencie todas as reservas</p>
                        <a asp-page="/Admin/Bookings/Index" class="btn btn-success">Acessar</a>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4 mb-4">
            <div class="col-md-6">
                <div class="card shadow-sm h-100">
                    <div class="card-body text-center">
                        <div class="display-4 text-primary mb-3">
                            <i class="bi bi-calendar-plus"></i>
                        </div>
                        <h5 class="card-title">Nova Reserva</h5>
                        <p class="card-text text-muted">Faça uma nova reserva de espaço</p>
                        <a asp-page="/Bookings/Create" class="btn btn-primary">Criar Reserva</a>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card shadow-sm h-100">
                    <div class="card-body text-center">
                        <div class="display-4 text-success mb-3">
                            <i class="bi bi-calendar-check"></i>
                        </div>
                        <h5 class="card-title">Minhas Reservas</h5>
                        <p class="card-text text-muted">Visualize suas reservas ativas e histórico</p>
                        <a asp-page="/Bookings/My" class="btn btn-success">Ver Reservas</a>
                    </div>
                </div>
            </div>
        </div>
    }

    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Informações da Conta</h5>
                    <p class="mb-1"><strong>Nome:</strong> @Model.UserName</p>
                    <p class="mb-1"><strong>Email:</strong> @Model.UserEmail</p>
                    <p class="mb-3"><strong>Perfil:</strong> @(Model.IsAdmin ? "Administrador" : "Usuário Comum")</p>
                    <a asp-page="/Profile/Edit" class="btn btn-outline-primary">Editar Perfil</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
}

