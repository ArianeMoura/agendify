# ─────────────────────────────────────────────────────────────
# Template de variáveis de ambiente do agendify.
# Copie para .env (ignorado pelo git) e preencha. NÃO commite segredos.
# Em .NET, o separador ":" das chaves de config vira "__" (duplo underscore).
# ─────────────────────────────────────────────────────────────

# API (src/api) — em desenvolvimento local, prefira User Secrets:
#   cd src/api && dotnet user-secrets set "DatabaseSettings:ConnectionString" "..."
# Em produção (Azure App Service / containers), use estas variáveis:
DatabaseSettings__ConnectionString=mongodb+srv://USUARIO:SENHA@host/?retryWrites=true&w=majority
JwtSettings__Secret=gere-um-segredo-forte-com-openssl-rand-base64-48

# Origens extras permitidas no CORS (separadas por vírgula), além das já fixas no código.
CORS_ALLOWED_ORIGINS=

# Testes de integração (src/api.Tests) — cluster Mongo usado pelos testes:
#   AGENDIFY_TEST_MONGO="mongodb+srv://..." dotnet test
AGENDIFY_TEST_MONGO=
