# ─────────────────────────────────────────────────────────────
# Template de variáveis de ambiente do agendify.
# Copie para .env (ignorado pelo git) e preencha. NÃO commite segredos.
# Em .NET, o separador ":" das chaves de config vira "__" (duplo underscore).
# ─────────────────────────────────────────────────────────────

# API (src/api) — em desenvolvimento local, prefira User Secrets:
#   cd src/api && dotnet user-secrets set "DatabaseSettings:ConnectionString" "..."
# Em produção (Render + Neon — ver docs/DEPLOYMENT.md), use estas variáveis.
DatabaseSettings__ConnectionString=Host=localhost;Port=5432;Database=agendify;Username=agendify;Password=SENHA
JwtSettings__Secret=gere-um-segredo-forte-com-openssl-rand-base64-48

# Origens permitidas no CORS (separadas por vírgula). Sem hardcode no código.
CORS_ALLOWED_ORIGINS=http://localhost:5292,http://localhost:3000

# Aplica as migrations no boot. Em Development já é automático; em produção
# defina como true (é o que o Render usa).
ApplyMigrationsOnStartup=false

# Envio de convites por e-mail (Resend). Sem a ApiKey, a API não envia nada:
# apenas registra o link de aceite no log (LoggingEmailSender) — útil em dev.
Email__ApiKey=
Email__FromAddress=onboarding@resend.dev
Email__FromName=Agendify

# Storage das imagens de espaço (Cloudflare R2, ou qualquer bucket S3-compatível).
# Sem Storage__Bucket, a API grava no disco local e serve em /uploads — bom em dev, mas
# no Render o disco é efêmero e as imagens somem a cada deploy. Preencha em produção.
# ServiceUrl no R2: https://<account_id>.r2.cloudflarestorage.com
# PublicBaseUrl: o domínio r2.dev do bucket ou um domínio próprio (é o que vai no banco).
Storage__ServiceUrl=
Storage__Bucket=
Storage__AccessKeyId=
Storage__SecretAccessKey=
Storage__PublicBaseUrl=

# Testes de integração (src/api.Tests) — Postgres usado pelos testes.
# Se vazio, a suíte sobe um container efêmero via Testcontainers (requer Docker).
#   AGENDIFY_TEST_POSTGRES="Host=localhost;Port=5432;Database=agendify_test;Username=agendify;Password=..." dotnet test
AGENDIFY_TEST_POSTGRES=

# docker/docker-compose.yml — senha do Postgres local:
POSTGRES_PASSWORD=troque-esta-senha
