# Copie este arquivo para docker/.env e preencha com valores locais.
# docker/.env é ignorado pelo git (nunca commite senhas).
#
#   cp docker/.env.example docker/.env
#
# Senha do PostgreSQL local, exigida por docker/docker-compose.yml
# (a fonte de verdade migrou de MongoDB para PostgreSQL). Não use em produção.
POSTGRES_PASSWORD=troque-esta-senha
