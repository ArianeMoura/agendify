# Estilo de código do Agendify. O que está aqui é aplicado por `dotnet format` e pelos
# IDEs (Visual Studio, Rider, VS Code com C# Dev Kit) — não é decoração.
#
# Admin e mobile têm suas próprias ferramentas (Prettier/ESLint, com `format:check` na CI);
# este arquivo trata do que elas não cobrem.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
trim_trailing_whitespace = true

[*.{json,yml,yaml}]
indent_size = 2

[*.md]
# Dois espaços no fim da linha são quebra de linha em Markdown.
trim_trailing_whitespace = false

[*.cs]
indent_size = 4
max_line_length = 110

# ---- Estilo da linguagem ----

# Namespace file-scoped (C# 10+): menos um nível de indentação em todo arquivo. É o default
# dos templates atuais da Microsoft. O projeto foi convertido de uma vez (`dotnet format`)
# para não conviver com os dois estilos. Exceção: os `.Designer.cs` e o ModelSnapshot do EF
# seguem block-scoped — são auto-gerados, o format os pula de propósito, e reescrevê-los à
# mão só duraria até a próxima migration.
csharp_style_namespace_declarations = file_scoped:warning

csharp_using_directive_placement = outside_namespace:warning
dotnet_sort_system_directives_first = true
csharp_prefer_braces = true:suggestion
csharp_style_var_for_built_in_types = false:silent
csharp_style_var_when_type_is_apparent = true:suggestion

# Expression-bodied só onde encurta de verdade.
csharp_style_expression_bodied_methods = when_on_single_line:suggestion
csharp_style_expression_bodied_properties = true:suggestion

# ---- Nomes ----

dotnet_naming_rule.private_fields_underscore.severity = suggestion
dotnet_naming_rule.private_fields_underscore.symbols = private_fields
dotnet_naming_rule.private_fields_underscore.style = underscore_prefix

dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private

dotnet_naming_style.underscore_prefix.capitalization = camel_case
dotnet_naming_style.underscore_prefix.required_prefix = _

# ---- Diagnósticos ----

# Async sem await é quase sempre engano.
dotnet_diagnostic.CS1998.severity = warning
