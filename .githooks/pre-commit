#!/bin/sh
# Bloqueia commits que contenham segredos. Ative uma vez com:
#   git config core.hooksPath .githooks
#
# Requer o gitleaks: `brew install gitleaks` (precisa das Command Line Tools —
# `xcode-select --install`) ou o binário de github.com/gitleaks/gitleaks/releases.
#
# Sem o gitleaks o hook avisa e deixa passar, em vez de travar o commit. Isso é
# aceitável porque não é a única camada: o Push Protection do GitHub barra
# segredos no push e o CI roda o gitleaks em todo push/PR. Este hook é a camada
# que avisa antes, quando corrigir ainda é de graça.

if ! command -v gitleaks >/dev/null 2>&1; then
  echo "⚠  gitleaks não instalado — pulando verificação de segredos."
  echo "   Instale com 'brew install gitleaks' ou baixe de github.com/gitleaks/gitleaks/releases"
  exit 0
fi

echo "🔎 Verificando segredos com gitleaks (staged)..."
if ! gitleaks git --pre-commit --staged --verbose; then
  echo "❌ Commit bloqueado: possível segredo detectado. Remova-o antes de commitar."
  exit 1
fi
echo "✅ Nenhum segredo detectado."
exit 0
